# Model weights - ~200 MB, placed here via tools/export_onnx.py or docker pull.
# Never committed; shipped into the runtime image via Dockerfile COPY.
model/*.bin
model/*.onnx

# Test fixtures - sourced from the TARAS_Disease dataset at build prep time.
tests/fixtures/*.jpg
tests/fixtures/*.JPG

# Parity goldens - generated by tools/export_onnx.py, tied to a specific .bin.
tests/golden_probs.json

# Python bytecode + pytest cache
__pycache__/
*.py[cod]
.pytest_cache/

# Smoke-test output from swap_forward.bat
swap_response.json
