# TARAS Backend Deployment Script
# Copy this file to deploy.ps1 and fill in your credentials

# ============================================
# CONFIGURATION - Fill these in
# ============================================
$EC2_IP = ""                                    # Your EC2 public IP
$EC2_USER = "ec2-user"                          # EC2 username (usually ec2-user for Amazon Linux)
$SSH_KEY = "$PSScriptRoot\your-key.pem"         # Path to your SSH private key
$BACKEND_PATH = "$PSScriptRoot"                 # Path to Backend folder
$RDS_ENDPOINT = ""                              # RDS endpoint (e.g., mydb.xxx.region.rds.amazonaws.com)
$RDS_PASSWORD = ""                              # RDS master password
$RDS_USER = "tarasmaster"                       # RDS username
$RDS_DB = "postgres"                            # Database name

# ============================================
# SCRIPT - Don't modify below unless needed
# ============================================
$ErrorActionPreference = "Stop"
$zipFile = "$PSScriptRoot\Backend_deploy.zip"

# Validate configuration
if (-not $EC2_IP) { Write-Host "ERROR: Set EC2_IP in deploy.ps1"; exit 1 }
if (-not $RDS_ENDPOINT) { Write-Host "ERROR: Set RDS_ENDPOINT in deploy.ps1"; exit 1 }
if (-not $RDS_PASSWORD) { Write-Host "ERROR: Set RDS_PASSWORD in deploy.ps1"; exit 1 }
if (-not (Test-Path $SSH_KEY)) { Write-Host "ERROR: SSH key not found at $SSH_KEY"; exit 1 }
if (-not (Test-Path "$BACKEND_PATH\package.json")) { Write-Host "ERROR: package.json not found"; exit 1 }

# Test SSH connection
Write-Host "Testing SSH connection..."
ssh -o ConnectTimeout=10 -i $SSH_KEY "$EC2_USER@$EC2_IP" "echo 'SSH OK'" 2>&1 | Out-Null
if ($LASTEXITCODE -ne 0) { Write-Host "ERROR: SSH connection failed"; exit 1 }

# Create deployment zip
Write-Host "Creating deployment package..."
if (Test-Path $zipFile) { Remove-Item $zipFile -Force }
Compress-Archive -Path `
    "$BACKEND_PATH\src", `
    "$BACKEND_PATH\prisma", `
    "$BACKEND_PATH\package.json", `
    "$BACKEND_PATH\package-lock.json", `
    "$BACKEND_PATH\tsconfig.json", `
    "$BACKEND_PATH\nodemon.json" `
    -DestinationPath $zipFile -Force

# Upload to EC2
Write-Host "Uploading to EC2..."
scp -i $SSH_KEY $zipFile "$EC2_USER@$EC2_IP`:/home/$EC2_USER/"
if ($LASTEXITCODE -ne 0) { Write-Host "ERROR: Upload failed"; exit 1 }

# Deploy on EC2
Write-Host "Deploying on EC2..."
$deployScript = @"
set -e
cd /home/$EC2_USER

# Clean and extract
rm -rf Backend
mkdir -p Backend
unzip -o Backend_deploy.zip -d Backend
cd Backend

# Create production .env
cat > .env << 'ENVEOF'
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://${RDS_USER}:${RDS_PASSWORD}@${RDS_ENDPOINT}:5432/${RDS_DB}
JWT_SECRET=`$(openssl rand -hex 32)
JWT_EXPIRES_IN=7d
CORS_ORIGINS=*
LOG_LEVEL=info
ENVEOF

# Install dependencies (Node.js should be installed system-wide)
npm install

# Build TypeScript
npm run build

# Run database migrations
npx prisma generate
npx prisma migrate deploy

# Restart PM2 process
pm2 delete taras-backend 2>/dev/null || true
pm2 start dist/index.js --name taras-backend
pm2 save

# Health check
sleep 3
echo ""
echo "=== Health Check ==="
curl -s http://localhost:3000/health || echo "Health check failed!"
echo ""
"@

$deployScript -replace "`r", "" | ssh -i $SSH_KEY "$EC2_USER@$EC2_IP" "bash -s"
if ($LASTEXITCODE -ne 0) { Write-Host "ERROR: Deployment failed"; exit 1 }

# Cleanup
Remove-Item $zipFile -Force

Write-Host ""
Write-Host "============================================"
Write-Host "Deployment complete!"
Write-Host "API URL: http://${EC2_IP}:3000"
Write-Host "Health:  http://${EC2_IP}:3000/health"
Write-Host "============================================"
