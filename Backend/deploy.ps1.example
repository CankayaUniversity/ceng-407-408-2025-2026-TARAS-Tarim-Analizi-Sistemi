# Config - fill these in
$EC2_IP = ""
$EC2_USER = "ec2-user"
$SSH_KEY = "$PSScriptRoot\your-key.pem"
$BACKEND_PATH = "$PSScriptRoot"
$RDS_ENDPOINT = ""
$RDS_PASSWORD = ""
$RDS_USER = "taras_user"
$RDS_DB = "taras_agricultural"

$ErrorActionPreference = "Stop"
$zipFile = "$PSScriptRoot\Backend_deploy.zip"

# Validate
if (-not $EC2_IP) { Write-Host "Set EC2_IP"; exit 1 }
if (-not $SSH_KEY -or -not (Test-Path $SSH_KEY)) { Write-Host "Set SSH_KEY"; exit 1 }
if (-not $BACKEND_PATH -or -not (Test-Path $BACKEND_PATH)) { Write-Host "Set BACKEND_PATH"; exit 1 }
if (-not (Test-Path "$BACKEND_PATH\.env")) { Write-Host "No .env in Backend"; exit 1 }
if (-not $RDS_PASSWORD) { Write-Host "Set RDS_PASSWORD"; exit 1 }

# Test SSH
Write-Host "Testing SSH..."
ssh -i $SSH_KEY "$EC2_USER@$EC2_IP" "echo ok" 2>&1 | Out-Null
if ($LASTEXITCODE -ne 0) { Write-Host "SSH failed"; exit 1 }

# Zip
Write-Host "Creating zip..."
if (Test-Path $zipFile) { Remove-Item $zipFile -Force }
Compress-Archive -Path "$BACKEND_PATH\src", "$BACKEND_PATH\prisma", "$BACKEND_PATH\package.json", "$BACKEND_PATH\package-lock.json", "$BACKEND_PATH\.env", "$BACKEND_PATH\tsconfig.json" -DestinationPath $zipFile -Force

# Upload
Write-Host "Uploading..."
scp -i $SSH_KEY $zipFile "$EC2_USER@$EC2_IP`:/home/$EC2_USER/"
if ($LASTEXITCODE -ne 0) { Write-Host "Upload failed"; exit 1 }

# Deploy
Write-Host "Deploying..."
$script = @"
set -e
cd /home/$EC2_USER
unzip -o Backend_deploy.zip
cd Backend

cat > .env << 'EOF'
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://$RDS_USER`:$RDS_PASSWORD@$RDS_ENDPOINT`:5432/$RDS_DB
JWT_SECRET=\$(openssl rand -hex 32)
JWT_EXPIRES_IN=7d
CORS_ORIGINS=*
EOF

npm install --production
npm run build
npx prisma migrate deploy

pm2 delete taras-backend 2>/dev/null || true
pm2 start npm --name taras-backend -- run dev
pm2 save

sleep 2
curl -s http://localhost:3000/health || echo "Health check failed"
"@

$script | ssh -i $SSH_KEY "$EC2_USER@$EC2_IP"
if ($LASTEXITCODE -ne 0) { Write-Host "Deploy failed"; exit 1 }

Remove-Item $zipFile -Force
Write-Host "Done: http://$EC2_IP`:3000"
