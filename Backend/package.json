{
  "name": "taras-backend",
  "version": "1.0.0",
  "description": "TARAS - Agricultural Analysis & Simulation Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "npx tsc && npm run copy:prisma",
    "copy:prisma": "node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\"",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "generate:tarik": "ts-node --require tsconfig-paths/register prisma/generate-tarik-data.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "agriculture",
    "iot",
    "sensors",
    "mqtt",
    "real-time"
  ],
  "author": "TARAS Team",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-iot-data-plane": "^3.971.0",
    "@aws-sdk/client-lambda": "^3.971.0",
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.5.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.33.0",
    "pg": "^8.17.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.15.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "axios": "^1.13.2",
    "eslint": "^9.39.2",
    "form-data": "^4.0.5",
    "jest": "^30.2.0",
    "nodemon": "^3.1.4",
    "prisma": "^7.5.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "prisma": {
    "seed": "ts-node --require tsconfig-paths/register prisma/seed.ts"
  }
}
