# API Configuration
# Set USE_LOCAL_API=true to use API_HOST_LOCAL, false to use API_HOST_AWS
USE_LOCAL_API=false
API_HOST_LOCAL=http://192.168.1.x:3000
API_HOST_AWS=http://your-server-ip:3000

# Local Demo Credentials (offline mode)
DEMO_USERNAME=your_demo_username
DEMO_PASSWORD=your_demo_password

# AWS Demo Credentials (for quick server login)
AWS_DEMO_USERNAME=your_aws_username
AWS_DEMO_PASSWORD=your_aws_password
